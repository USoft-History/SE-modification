	overflow:hidden;
	height:1%;
}
.panel{
	margin:10px 0 0;
	padding:0 30px 0 5px;
	list-style:none;
	background:url(../images/bg-panel.gif) repeat-x;
	height:25px;
	float:left;
	border:1px solid #bbb;
}
.panel li{
	float:left;
	margin:0 3px;
	display:inline;
}
.panel img{
	float:left;
}
.add-comment{
	float:left;
	clear:both;
	margin:13px 0 0;
	width:464px;
}
.add-comment fieldset{
	overflow:hidden;
}
.add-comment .textarea{
	background:url(../images/bg-textarea.gif) no-repeat;
	width:454px;
	height:161px;
	padding:5px;
	margin:0 0 15px;
}
.add-comment .textarea textarea{
	width:454px;
	height:161px;
	background:none;
	border:none;
	color:#D0D0D0;
	overflow:auto;
}
.add-comment input{
	float:right;
	clear:both;
}
.posts .laid-out{
	float:none;
	width:100%;
	overflow:hidden;
	margin:0 0 15px;
}
.posts .laid-out div{
	float:none;
	height:1%;
	overflow:hidden;
	padding:0 0 0 7px;
}
.posts-list{
	margin:0;
	padding:0;
	list-style:none;
	overflow:hidden;
	font-size:10px;
	line-height:12px;
	color:#dcdcdc;
}
.posts-list li{
	float:left;
	background:url(../images/bullit12.gif) repeat-y;
	margin:0 6px 0 -6px;
	padding:7px 5px 8px 11px;
}
.posts-list a{
	color:#dcdcdc;
}
.data{
	float:right;
	margin:5px 0 0;
	padding:0 3px 0 0;
	list-style:none;
	overflow:hidden;
}
.data li{
	float:left;
	background:url(../images/bullit13.gif) no-repeat 0 50%;
	margin:0 2px 0 -2px;
	padding:0 4px 0 6px;
}
/* end news2 */

#bbfix img {
	padding:0;
	margin:0;
}

.resizer {
	cursor:s-resize; 
	width:459px; 
	height:4px; 
	margin:2px 0 10px 0;
}

