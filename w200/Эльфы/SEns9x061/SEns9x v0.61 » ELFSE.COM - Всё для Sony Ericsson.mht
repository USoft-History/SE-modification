.download{
	width:100%;
	padding:0;
	margin:0;
}
.download .t-left{
	background:url(../images/bg-download-t-l.gif) no-repeat;
	height:31px;
	text-align:center;
	font-size:15px;
	line-height:17px;
	color:#dcdcdc;
}
.download .t-right{
	background:url(../images/bg-download-t-r.gif) no-repeat 100% 0;
	width:15px;
}
.download .c-left{
	background:#2d2f30 url(../images/bg-download-l.gif) repeat-y;
	padding:10px 0 0 10px;
}
.download .c-left img{
	float:left;
	margin:0 10px 0 0;
}
.download .c-left div{
	float:left;
	width:85%;
	padding:5px 0 0;
}
.download .c-left div p{
	margin:0 0 2px;
	color:#dcdcdc;
}
.download .c-left div p a{
	font-weight:bold;
	color:#449dd6;
}
.download .c-right{
	background:#2d2f30 url(../images/bg-download-r.gif) repeat-y 100% 0;
}
.download .b-left{
	background:url(../images/bg-download-b-l.gif) no-repeat;
	height:6px;
}
.download .b-right{
	background:url(../images/bg-download-b-r.gif) no-repeat 100% 0;
}
#coml a {
	color: #cecece;
	background-color: #444;
	text-decoration: none;
	border: 1px solid #888;
	padding-left: 2px;
	padding-right: 2px;
}

#coml a:hover {
		color: #fff;
		background-color: #086fa1;
}

.posts img{
	float:left;
	margin:0 15px 0 10px;
	display:inline;
}
.posts .user{
	background:url(../images/btn-user.gif) no-repeat;
}
#main .posts .vip{
	background:url(../images/btn-vip.gif) no-repeat;
	color:#4f390e;
}
.posts .user,
.posts .vip{
	width:102px;
	height:21px;
	display:block;
	float:left;
	margin:0 0 0 7px;
	text-align:center;
	color:#fff;
	font-size:11px;
	padding:4px 0 0;
}
.posts .user:hover,
.posts .vip:hover{
	text-decoration:none;
}
.center-holder{
	padding:10px 11px 0 5px;
}
.center-holder p{
	margin:0;
	line-height:17px;
}
.center-holder img{
	margin:0;
	float:none;
}
.posts .comment{
	float:right;
}
.posts{
	position:relative;
	height:1%;
}
.posts .button-box{
	padding:15px 0 18px
}
.posts-block .column .t{
	height:auto;
}
.comment-add{
	padding:13px 0 0 14px;
	overflow:hidden;
	height:1%;
}
.panel{
	margin:10px 0 0;
	padding:0 30px 0 5px;
	list-style:none;
	background:url(../images/bg-panel.gif) repeat-x;
	height:25px;
	float:left;
	border:1px solid #bbb;
}
.panel li{
	float:left;
	margin:0 3px;
	display:inline;
}
.panel img{
	float:left;
}
.add-comment{
	float:left;
	clear:both;
	margin:13px 0 0;
	width:464px;
}
.add-comment fieldset{
	overflow:hidden;
}
.add-comment .textarea{
	background:url(../images/bg-textarea.gif) no-repeat;
	width:454px;
	height:161px;
	padding:5px;
	margin:0 0 15px;
}
.add-comment .textarea textarea{
	width:454px;
	height:161px;
	background:none;
	border:none;
	color:#D0D0D0;
	overflow:auto;
}
.add-comment input{
	float:right;
	clear:both;
}
.posts .laid-out{
	float:none;
	width:100%;
	overflow:hidden;
	margin:0 0 15px;
}
.posts .laid-out div{
	float:none;
	height:1%;
	overflow:hidden;
	padding:0 0 0 7px;
}
.posts-list{
	margin:0;
	padding:0;
	list-style:none;
	overflow:hidden;
	font-size:10px;
	line-height:12px;
	color:#dcdcdc;
}
.posts-list li{
	float:left;
	background:url(../images/bullit12.gif) repeat-y;
	margin:0 6px 0 -6px;
	padding:7px 5px 8px 11px;
}
.posts-list a{
	color:#dcdcdc;
}
.data{
	float:right;
	margin:5px 0 0;
	padding:0 3px 0 0;
	list-style:none;
	overflow:hidden;
}
.data li{
	float:left;
	background:url(../images/bullit13.gif) no-repeat 0 50%;
	margin:0 2px 0 -2px;
	padding:0 4px 0 6px;
}
