}


body{
	margin:0;
	font:12px/14px Arial, Helvetica, sans-serif;
}
img{border-style:none;}

a{
	color:#c0c0c0;
	text-decoration:none;
}/*
a:visited{
	color:#73758a;
	text-decoration:none;
}*/
a:hover{
	text-decoration:underline;
}
input,
textarea,
select{
	font:100% arial,sans-serif;
	vertical-align:middle;
}
form,fieldset{
	margin:0;
	padding:0;
	border:none;
}
#wrapper01{
	background:#000 url(../images/bg-html.jpg) repeat-x 0 100%;
	min-width:999px
}
#wrapper{
	width:100%;
	background:url(../images/bg-body.jpg) repeat-x;
	table-layout:fixed;
}
#header{
	margin:auto;
	width:90%;
	background:url(../images/bg-header-holder.gif) no-repeat 100% 100%;
	position:relative;
}
#header h1{
	background:url(../images/logose.png) no-repeat;
	position:absolute;
	top:51px;
	left:0px;
	height:145px;
	margin:0;
}
.logo{
	background:url(../images/logo.png) no-repeat;
	width:454px;
	height:145px;
	text-indent:-9999px;
	overflow:hidden;
	display:block;
	scursor:pointer;
}
.logotext{
	position:absolute;
	top:111px;
	left:175px;
	color:#f0f0f0;
	font-weight:700;
}
.logotext a {
	color:#f0f0f0;
	}
#header .holder{
	background:url(../images/bg-header.gif) no-repeat 0 100%;
	width:100%;
	overflow:hidden;
	height:198px;
}
.form{
	float:right;
	background:url(../images/bg-form.png) no-repeat;
	width:331px;
	height:65px;
	margin:65px 12px 0 0;
	display:inline;
	padding:9px 0 0 8px;
}
.form fieldset{
	position:relative;
}
.form div{
	background:url(../images/bg-search.gif) no-repeat;
	width:216px;
	float:left;
	padding:0 8px;
}
.form .btn-search{
	float:left;
	background:url(../images/btn-search.gif) no-repeat;
	height:33px;
	border:none;
	text-indent:-9999px;
	overflow:hidden;
	width:88px;
	cursor:pointer;
}
/*
.form .btn-search:hover, .form .btn-search:active{
	background:url(../images/btn-search.gif) no-repeat 0 -33px;
}
*/
.form .btn-search:hover{
	background:url(../images/btn-search.gif) no-repeat 0 -33px;
}

.form .btn-search:active{
	background:url(../images/btn-search.gif) no-repeat 0 -66px;
}

.form .search{
	width:216px;
	background:none;
	border:none;
	color:#949494;
	font-size:13px;
	line-height:15px;
	font-style:italic;
	margin:8px 0;
}
.btn-search{
	background:url(../images/btn-search) no-repeat;
}
#nav{
	margin:0 0 9px;
	padding:0;
	list-style:none;
	position:absolute;
	bottom:0;
	right:34px;
	height:30px;
	overflow:hidden;
	font-size:13px;
	line-height:15px;
}
#nav li{
	float:left;
	height:30px;
	padding:0 0 0 14px;
}
#nav a{
	float:left;
	color:#e9e9e9;
	background:url(../images/bg-nav-right.gif) no-repeat 100% 0;
	height:30px;
}
#nav span{
	float:left;
	height:24px;
	background:url(../images/bg-nav-left.gif) no-repeat;
	padding:6px 13px 0;
	cursor:pointer;
}
/*
#nav a:hover, #nav a:active{
	background:url(../images/bg-nav-right.gif) no-repeat 100% -30px;
	text-decoration:none;
}
#nav a:hover span, #nav a:active span{
	background:url(../images/bg-nav-left.gif) no-repeat 0 -30px;
}
*/

#nav a:hover{
	background:url(../images/bg-nav-right.gif) no-repeat 100% -30px;
	text-decoration:none;
}
#nav a:hover span{
	background:url(../images/bg-nav-left.gif) no-repeat 0 -30px;
}
#nav a:active{
	background:url(../images/bg-nav-right.gif) no-repeat 100% -60px;
	text-decoration:none;
}
#nav a:active span{
	background:url(../images/bg-nav-left.gif) no-repeat 0 -60px;
}

/* NAV_A */
#nava{
	margin:0 0 7px;
	padding:0;
	list-style:none;
	position:absolute;
	bottom:0;
	right:34px;
	height:20px;
	overflow:hidden;
	font-size:13px;
	line-height:9px;
}
#nava li{
	float:left;
	height:20px;
	padding:0 0 0 14px;
}
#nava a{
	float:left;
	color:#e9e9e9;
	background:url(../images/bg-nav-righta.png) no-repeat 100% 0;
	height:20px;
}
#nava span{
	float:left;
	height:24px;
	background:url(../images/bg-nav-lefta.png) no-repeat;
	padding:6px 13px 0;
	cursor:pointer;
}
/*
#nava a:hover, #nava a:active{
	background:url(../images/bg-nav-righta.png) no-repeat 100% -30px;
	text-decoration:none;
}
#nava a:hover span, #nava a:active span{
	background:url(../images/bg-nav-lefta.gif) no-repeat 0 -30px;
}
*/

#nava a:hover{
	background:url(../images/bg-nav-righta.png) no-repeat 100% -20px;
	text-decoration:none;
}
#nava a:hover span{
	background:url(../images/bg-nav-lefta.png) no-repeat 0 -20px;
}
#nava a:active{
	background:url(../images/bg-nav-righta.png) no-repeat 100% -40px;
	text-decoration:none;
}
#nava a:active span{
	background:url(../images/bg-nav-lefta.png) no-repeat 0 -40px;
}
/* END NAV_A*/

#main{
	margin:auto;
	width:90%;
	background:url(../images/bg-main-shadow01.jpg) no-repeat;
	padding:0 0 114px;
}
.main-holder{
	height:1%;
	background:url(../images/bg-main-shadow02.jpg) no-repeat 100% 0;
	padding:0 9px;
}
#content{
	background:#232426 url(../images/hr01.gif) repeat-x;
}
.columns{
	overflow:hidden;
	color:#d0d0d0;
	margin:0 0 15px;
	width:100%;
}
.column table{
	padding:0;
	vertical-align: top;
}
.empty-line{
	height:13px;
}
.column{
	background:url(../images/bg-column-bottom.gif) repeat-x 0 100%;
	table-layout:fixed;
	width:100%;
	height: 100%;
	border-collapse:collapse;
	padding:0;
	margin:0;
	color:#d0d0d0;
	vertical-align:top;
}
.column .tl{
	background:url(../images/bg-column-left.gif) no-repeat;
	width:5px;
}
.column .t{
	background:#383b3b url(../images/bg-column-top.gif) repeat-x;
	height:260px;
	vertical-align:top;
}
.column .t table{
	height:100%;
}
#column_fix .t {
	height:80px;
}
.column .tr{
	background:url(../images/bg-column-right.gif) no-repeat;
	width:7px;
}
.column .bl{
	background:url(../images/bg-corner1.gif) no-repeat;
	height:13px;
}
.column .b{
	background:url(../images/bg-column-bottom.gif) repeat-x;
	height:7px;
}
.column .br{
	background:url(../images/bg-corner2.gif) no-repeat;
	height:13px;
}
.column .head{
	text-transform:uppercase;
	color:#fff;
	font-size:11px;
	line-height:13px;
	display:block;
	padding:0 0 0 15px;
}
.column .head a{
	color:#fff;
}
.column .head_com{
	text-transform:uppercase;
	color:#fff;
	font-size:11px;
	line-height:13px;
	display:block;
	padding:0 0 0 15px;
	font-weight:500;
}
.column .head_com a{
	color:#fff;
}
.column .center{
padding:10px 9px 0 11px;
height:1%;
}
/*
.column .center{
	padding:10px 9px 0 11px;
	height:1%;
	overflow:hidden;
}
*/
.column .left{
	width:100%;
	float:left;
}
.column p{
	margin:0 0 15px;
}
.column .left p a{
	color:#f3f3f3;
	font-weight:bold;
}
.column .left ul{
	margin:0;
	padding:0;
	list-style:none;
}
.column .left ul li{
	background:url(../images/hr02.gif) repeat-x 0 100%;
	padding:4px 0 5px;
}
.column .left ul a{
	color:#d0d0d0;
}
.column .right{
	width:100px;
	float:right;
}
.column .right img{
	margin:0 auto 19px;
	display:block;
	border:1px solid #cbd2c6;
}
.column .exit{
	background:url(../images/btn-left.gif) no-repeat;
	width:99px;
	display:block;
	margin:0 auto;
