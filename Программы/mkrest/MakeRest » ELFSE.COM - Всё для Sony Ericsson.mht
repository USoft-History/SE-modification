	clear:both;
}
.posts .laid-out{
	float:none;
	width:100%;
	overflow:hidden;
	margin:0 0 15px;
}
.posts .laid-out div{
	float:none;
	height:1%;
	overflow:hidden;
	padding:0 0 0 7px;
}
.posts-list{
	margin:0;
	padding:0;
	list-style:none;
	overflow:hidden;
	font-size:10px;
	line-height:12px;
	color:#dcdcdc;
}
.posts-list li{
	float:left;
	background:url(../images/bullit12.gif) repeat-y;
	margin:0 6px 0 -6px;
	padding:7px 5px 8px 11px;
}
.posts-list a{
	color:#dcdcdc;
}
.data{
	float:right;
	margin:5px 0 0;
	padding:0 3px 0 0;
	list-style:none;
	overflow:hidden;
}
.data li{
	float:left;
	background:url(../images/bullit13.gif) no-repeat 0 50%;
	margin:0 2px 0 -2px;
	padding:0 4px 0 6px;
}
/* end news2 */

#bbfix img {
	padding:0;
	margin:0;
}

.resizer {
	cursor:s-resize; 
	width:459px; 
	height:4px; 
	margin:2px 0 10px 0;
}

