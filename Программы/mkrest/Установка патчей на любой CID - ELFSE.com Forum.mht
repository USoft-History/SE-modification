	float:left;
	margin:0 1px;
	display:inline;
}
.nav ul a{
	float:left;
	padding:2px 6px 3px;
	background:url(../../images/elfse/gradients/bg-nav.gif) repeat-x;
}
.nav ul a:hover,
.nav ul .active a{
	background:url(../../images/elfse/gradients/bg-nav-hover.gif) repeat-x;
}
.nav a{
	text-align:center;
	color:#dcdcdc;
	cursor:pointer;
}
.nav a:hover{
	text-decoration:none;
}
.nav .none a{
	background:none;
}
.center-coll{
	float:left;
}
