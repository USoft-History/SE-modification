}
.list-bottom .user{
	background:url(../../images/elfse/gradients/bg-main-list-bottom-c02.gif) repeat-x;
}
.list-bottom .viewing{
	background:url(../../images/elfse/gradients/bg-main-list-bottom-c01.gif) repeat-x;
}
.list-bottom .answer{
	background:url(../../images/elfse/gradients/bg-main-list-bottom-r.gif) no-repeat 100% 0;
}
.columns-list{
	margin:0;
}
.columns-list .t{
	height:310px;
}
.describe{
	margin:0;
	padding:10px 0 0 10px;
