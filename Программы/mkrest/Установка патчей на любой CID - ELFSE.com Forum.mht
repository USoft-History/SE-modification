}

#mincat a:hover {
	background: #0d83f0;
	color: #fff;
}

.line01{
	height:36px;
}
.line02{
	height:13px;
}
#footer{
	height:1%;
	padding:13px 0 0 20px;
}
#footer:after{
	content:"";
	display:block;
	clear:both;
}
#footer .holder{
	float:left;
