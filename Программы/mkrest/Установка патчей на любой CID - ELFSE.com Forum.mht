Content-Transfer-Encoding: 8bit

.spoiler {
	margin: 20px 30px 10px;
	-moz-border-radius: 5px;
	-webkit-border-radius: 5px;
	background: #5a5d5d none;
	border-radius: 5px;
	border: 1px solid #535e6e;
}
.spoiler > h2 {
	background: transparent url(icon_plus.png) no-repeat left center;
	font: italic normal 13px Tahoma,Calibri,Verdana,Geneva,sans-serif;
	font-size: 11px;
	padding: 3px 17px;
	margin: 0 0 0 3px;
	line-height: 15px;
	font-weight: bold;
	cursor: pointer;
}
.spoiler > div {
	display: none;
	padding: 2px 6px;
	overflow: hidden;
	border-top: 1px solid #C3CBD1;
}
h2.vsqminus {
	background: transparent url(icon_minus.png) no-repeat left center;
}
.sphide {
	cursor: pointer;
	text-align: right;
	font-weight: bold;
}
