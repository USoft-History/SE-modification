}
.nav .inner{
	 position:relative;
	left:50%;
	float:left;
	text-align:center;
}
.nav .inner div{
	position:relative;
	float:left;
	left:-50%;
}
.nav .back,
.nav .next{
	float:left;
	background:url(../../images/elfse/gradients/bg-nav.gif) repeat-x;
	width:53px;
	height:18px;
	padding:1px 0 0;
