}
.laid-out div{
	background:url(../../images/elfse/gradients/bg-laid-out-right.gif) no-repeat 100% 0;
	overflow:hidden;
	height:28px;
	padding:0 10px;
	float:left;
	line-height:15px;
}
.laid-out img{
	float:left;
	padding-top:4px;
}
.laid-out span{
	float:left;
	color:#dcdcdc;
	padding:5px 0 0;
}
.laid-out span a{
	color:#449dd6;
	font-weight:bold;
