	background:url(../../images/elfse/gradients/btn-more1.gif) no-repeat 0 -28px;
}
.comment:hover,
.button-box .more:hover,
.button-box a:hover{
	text-decoration:none;
}
.author{
	width:100%;
	overflow:hidden;
