}
.navigation .holder{
	background:url(../../images/elfse/gradients/bg-navigation-right.gif) no-repeat 100% 0;
	height:32px;
	width:100%;
	margin-top:-9px;
	padding-top:9px;
}
.nav{
	width:100%;
	overflow:hidden;
	position:relative;
